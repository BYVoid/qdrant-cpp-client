# The client uses C++20 (std::span in the public API).
build --cxxopt=-std=c++20
build --host_cxxopt=-std=c++20

# Keep third-party (@grpc, @abseil-cpp, …) warning noise out of the build;
# first-party sources still warn.
build --per_file_copt=external/.*@-w
build --host_per_file_copt=external/.*@-w

# The client only needs gRPC's core; don't compile Envoy/xDS from @grpc.
build --define=grpc_no_xds=true
test --define=grpc_no_xds=true

common --enable_platform_specific_config

# Bazel 9 removed the native cc_*/py_* rules; some @grpc third_party BUILD
# files (e.g. third_party/address_sorting) still call native.cc_library.
# Autoload the removed-rule shims so they keep resolving.
common --incompatible_autoload_externally=+cc_library,+cc_test,+cc_binary,+py_binary

# gRPC/protobuf transitively repeat system libraries on macOS; keep the
# Apple linker (Xcode 15+) from reporting duplicate -lm/-lpthread noise.
build:macos --linkopt=-Wl,-no_warn_duplicate_libraries
build:macos --host_linkopt=-Wl,-no_warn_duplicate_libraries

test --test_output=errors
